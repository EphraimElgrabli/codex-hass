#!/usr/bin/env bash
set -euo pipefail

font_size="$(jq -r '.terminal_font_size // 14' /data/options.json)"
theme="$(jq -r '.terminal_theme // "dark"' /data/options.json)"
session_persist="$(jq -r '.session_persistence // true' /data/options.json)"
work_dir="$(jq -r '.working_directory // "/homeassistant"' /data/options.json)"
enable_mcp="$(jq -r '.enable_mcp // true' /data/options.json)"
default_model="$(jq -r '.default_model // ""' /data/options.json)"
codex_permissions="$(jq -r '.codex_permissions // "workspace"' /data/options.json)"

export CODEX_STATE_ROOT="/data/codex-home"
export CODEX_MANAGED_ROOT="/data/codex-managed"
export CODEX_WORK_DIR="$work_dir"
export CODEX_SESSION_PERSIST="$session_persist"
export CODEX_ENABLE_MCP="$enable_mcp"
export CODEX_DEFAULT_MODEL="$default_model"
export CODEX_PERMISSIONS="$codex_permissions"
export CODEX_HA_URL="http://supervisor/core"
export CODEX_SUPERVISOR_TOKEN_FILE="/tmp/codex/ha-token"

mkdir -p \
  "$CODEX_STATE_ROOT/users" \
  "$CODEX_MANAGED_ROOT" \
  /tmp/codex

chmod 700 /tmp/codex

if [[ -d /homeassistant/.codex-home && ! -d "$CODEX_STATE_ROOT/legacy-global-home" ]]; then
  cp -a /homeassistant/.codex-home "$CODEX_STATE_ROOT/legacy-global-home"
  echo "[INFO] Backed up legacy Codex state from /homeassistant/.codex-home to $CODEX_STATE_ROOT/legacy-global-home"
fi

grant_group_root_access() {
  local target="$1"
  if [[ ! -e "$target" ]]; then
    return
  fi

  if ! setfacl -R -m g:root:rwx "$target" 2>/dev/null; then
    chmod -R g+rwX "$target" 2>/dev/null || true
  fi

  if [[ -d "$target" ]]; then
    setfacl -R -d -m g:root:rwx "$target" 2>/dev/null || true
  fi
}

grant_group_root_access /homeassistant
grant_group_root_access /share
grant_group_root_access /media
grant_group_root_access "$work_dir"

printf '%s' "${SUPERVISOR_TOKEN:-}" > "$CODEX_SUPERVISOR_TOKEN_FILE"
chmod 600 "$CODEX_SUPERVISOR_TOKEN_FILE"

cat > "$CODEX_MANAGED_ROOT/AGENTS.md" <<'EOF'
# Codex - Home Assistant Add-on

## Path Mapping

In this add-on container, paths are mapped differently than HA Core:
- `/homeassistant` = HA config directory (equivalent to `/config` in HA Core)
- `/config` does NOT exist - always use `/homeassistant`

When users mention `/config/...`, translate to `/homeassistant/...`

## Available Paths

| Path | Description | Access |
|------|-------------|--------|
| `/homeassistant` | HA configuration | read-write |
| `/share` | Shared folder | read-write |
| `/media` | Media files | read-write |
| `/ssl` | SSL certificates | read-only |
| `/backup` | Backups | read-only |

## Codex Configuration

- The add-on manages Codex state under `/data/codex-home/users/anonymous/.codex` in direct-ttyd ingress mode.
- The terminal uses the shared Home Assistant ingress session identity unless ttyd provides a user id.
- This global `~/.codex/AGENTS.md` file is generated by the add-on.
- The add-on merges managed defaults into `~/.codex/config.toml` without removing unrelated user settings.
- Put project instructions in `/homeassistant/AGENTS.md` (or nested `AGENTS.md` files).
- Put project-specific config in `/homeassistant/.codex/config.toml`.
- Codex only loads project-specific config from trusted projects, so trust `/homeassistant` before relying on `/homeassistant/.codex/config.toml`.

## Home Assistant Integration

Use the `homeassistant` MCP server to query entities and call services when MCP is enabled. The Supervisor token stays outside the interactive shell and is only available through the privileged `hass-mcp` helper path.

## Reading Home Assistant Logs

**Log levels (from most to least verbose):**
- `debug` - Only shown if explicitly enabled in configuration.yaml
- `info` - General information, shown by default
- `warning` - Warnings, always shown
- `error` - Errors, always shown

**Commands to read logs:**
```bash
# View recent logs (ha CLI)
ha core logs 2>&1 | tail -100

# Filter by keyword
ha core logs 2>&1 | grep -i keyword

# Filter errors only
ha core logs 2>&1 | grep -iE "(error|exception)"

# Alternative: read log file directly
tail -100 /homeassistant/home-assistant.log
```

**To enable debug logging for an integration**, add to `configuration.yaml`:
```yaml
logger:
  default: info
  logs:
    custom_components.YOUR_INTEGRATION: debug
```

**Key insight:** `_LOGGER.debug()` calls are invisible unless the logger level is set to debug. Use `_LOGGER.info()` or `_LOGGER.warning()` for logs that should always appear.
EOF

validate_home="$CODEX_MANAGED_ROOT/validate-home"
rm -rf "$validate_home"
mkdir -p "$validate_home"
trap 'rm -rf "$validate_home"' EXIT
/usr/local/bin/codex-merge-config "${validate_home}/config.toml" "$default_model" "$enable_mcp" "$codex_permissions"
if [[ "$enable_mcp" == "true" ]]; then
  CODEX_HOME="$validate_home" codex mcp get homeassistant >/dev/null
  echo "[INFO] Home Assistant MCP configured for Codex home"
else
  CODEX_HOME="$validate_home" codex mcp list >/dev/null
  echo "[INFO] Home Assistant MCP disabled"
fi
rm -rf "$validate_home"
trap - EXIT

if [[ "$theme" == "dark" ]]; then
  colors='background=#1e1e2e,foreground=#cdd6f4,cursor=#f5e0dc'
else
  colors='background=#eff1f5,foreground=#4c4f69,cursor=#dc8a78'
fi

unset SUPERVISOR_TOKEN

exec ttyd \
  --port 7681 \
  --writable \
  --ping-interval 30 \
  --max-clients 20 \
  -t "fontSize=${font_size}" \
  -t fontFamily=Monaco,Consolas,monospace \
  -t scrollback=20000 \
  -t "theme=${colors}" \
  /usr/local/bin/codex-session
