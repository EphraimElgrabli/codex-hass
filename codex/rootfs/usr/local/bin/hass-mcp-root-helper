#!/usr/bin/env bash
set -euo pipefail

TOKEN_FILE="${CODEX_SUPERVISOR_TOKEN_FILE:-/tmp/codex/ha-token}"
HA_URL_VALUE="${CODEX_HA_URL:-http://supervisor/core}"

if [[ ! -r "$TOKEN_FILE" ]]; then
  echo "[ERROR] Supervisor token file is not readable: $TOKEN_FILE" >&2
  exit 1
fi

export HA_TOKEN
HA_TOKEN="$(<"$TOKEN_FILE")"
export HA_URL="$HA_URL_VALUE"

exec hass-mcp "$@"
