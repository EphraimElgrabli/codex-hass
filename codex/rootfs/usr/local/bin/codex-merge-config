#!/usr/bin/env python3
import json
import os
import shutil
import sys
import tempfile
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover
    print("tomllib is required", file=sys.stderr)
    sys.exit(1)


def format_scalar(value):
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        return repr(value)
    if isinstance(value, str):
        return json.dumps(value)
    if isinstance(value, list):
        return "[" + ", ".join(format_inline(item) for item in value) + "]"
    if isinstance(value, dict):
        items = ", ".join(f"{key} = {format_inline(val)}" for key, val in value.items())
        return "{ " + items + " }"
    raise TypeError(f"Unsupported TOML value type: {type(value)!r}")


def format_inline(value):
    if isinstance(value, dict):
        items = ", ".join(f"{key} = {format_inline(val)}" for key, val in value.items())
        return "{ " + items + " }"
    return format_scalar(value)


def emit_table(lines, table_name, mapping):
    scalar_items = []
    child_tables = []
    for key, value in mapping.items():
        if isinstance(value, dict):
            child_tables.append((key, value))
        else:
            scalar_items.append((key, value))

    if table_name:
        lines.append(f"[{table_name}]")
    for key, value in scalar_items:
        lines.append(f"{key} = {format_scalar(value)}")
    if table_name and child_tables:
        lines.append("")

    for index, (key, value) in enumerate(child_tables):
        child_name = f"{table_name}.{key}" if table_name else key
        emit_table(lines, child_name, value)
        if index != len(child_tables) - 1:
            lines.append("")


def load_existing_config(path):
    if not path.exists():
        return {}

    try:
        with path.open("rb") as handle:
            loaded = tomllib.load(handle)
    except tomllib.TOMLDecodeError:
        backup_path = path.with_suffix(path.suffix + ".invalid.bak")
        shutil.copy2(path, backup_path)
        return {}

    if not isinstance(loaded, dict):
        return {}
    return loaded


def main():
    if len(sys.argv) not in (4, 5, 6):
        print(
            "usage: codex-merge-config <config_path> <default_model> <enable_mcp> [codex_permissions] [codex_approval_policy]",
            file=sys.stderr,
        )
        return 1

    config_path = Path(sys.argv[1])
    default_model = sys.argv[2]
    enable_mcp = sys.argv[3].lower() == "true"
    codex_permissions = sys.argv[4] if len(sys.argv) >= 5 else "workspace"
    codex_approval_policy = sys.argv[5] if len(sys.argv) == 6 else "on-request"

    config_path.parent.mkdir(parents=True, exist_ok=True)
    config = load_existing_config(config_path)

    legacy_metadata = config.pop("__homeassistant_addon", None)
    if "__homeassistant_app" not in config and isinstance(legacy_metadata, dict):
        config["__homeassistant_app"] = legacy_metadata

    metadata = config.setdefault("__homeassistant_app", {})
    if not isinstance(metadata, dict):
        metadata = {}
        config["__homeassistant_app"] = metadata

    previous_managed_model = metadata.get("managed_model")
    if default_model:
        if "model" not in config or previous_managed_model is not None or config.get("model") == previous_managed_model:
            config["model"] = default_model
            metadata["managed_model"] = default_model
        else:
            metadata.pop("managed_model", None)
    elif config.get("model") == previous_managed_model:
        config.pop("model", None)
        metadata.pop("managed_model", None)
    else:
        metadata.pop("managed_model", None)

    permission_profiles = {
        "workspace": "workspace-write",
        "full_access": "danger-full-access",
    }
    managed_sandbox_mode = permission_profiles.get(codex_permissions)
    previous_managed_sandbox_mode = metadata.get("managed_sandbox_mode")
    if managed_sandbox_mode:
        should_manage_sandbox = (
            "sandbox_mode" not in config
            or previous_managed_sandbox_mode is not None
            or codex_permissions == "full_access"
            or config.get("sandbox_mode") == previous_managed_sandbox_mode
        )
        if should_manage_sandbox:
            config["sandbox_mode"] = managed_sandbox_mode
            metadata["managed_sandbox_mode"] = managed_sandbox_mode
        else:
            metadata.pop("managed_sandbox_mode", None)
    elif config.get("sandbox_mode") == previous_managed_sandbox_mode:
        config.pop("sandbox_mode", None)
        metadata.pop("managed_sandbox_mode", None)
    else:
        metadata.pop("managed_sandbox_mode", None)

    approval_policies = {
        "on-request": "on-request",
        "never": "never",
        "untrusted": "untrusted",
    }
    managed_approval_policy = approval_policies.get(codex_approval_policy)
    previous_managed_approval_policy = metadata.get("managed_approval_policy")
    if managed_approval_policy:
        should_manage_approval_policy = (
            "approval_policy" not in config
            or previous_managed_approval_policy is not None
            or codex_approval_policy == "never"
            or config.get("approval_policy") == previous_managed_approval_policy
        )
        if should_manage_approval_policy:
            config["approval_policy"] = managed_approval_policy
            metadata["managed_approval_policy"] = managed_approval_policy
        else:
            metadata.pop("managed_approval_policy", None)
    elif config.get("approval_policy") == previous_managed_approval_policy:
        config.pop("approval_policy", None)
        metadata.pop("managed_approval_policy", None)
    else:
        metadata.pop("managed_approval_policy", None)

    mcp_servers = config.setdefault("mcp_servers", {})
    if not isinstance(mcp_servers, dict):
        mcp_servers = {}
        config["mcp_servers"] = mcp_servers

    existing_homeassistant = mcp_servers.get("homeassistant", {})
    if not isinstance(existing_homeassistant, dict):
        existing_homeassistant = {}

    if enable_mcp:
        preserved_homeassistant = metadata.pop("managed_homeassistant_mcp_backup", {})
        if not isinstance(preserved_homeassistant, dict):
            preserved_homeassistant = {}
        merged_homeassistant = dict(preserved_homeassistant)
        merged_homeassistant.update(existing_homeassistant)
        merged_homeassistant["command"] = "/usr/local/bin/hass-mcp-wrapper"
        mcp_servers["homeassistant"] = merged_homeassistant
        metadata["managed_homeassistant_mcp"] = True
    else:
        if existing_homeassistant:
            metadata["managed_homeassistant_mcp_backup"] = dict(existing_homeassistant)
        mcp_servers.pop("homeassistant", None)
        metadata.pop("managed_homeassistant_mcp", None)

    if not mcp_servers:
        config.pop("mcp_servers", None)
    if not metadata:
        config.pop("__homeassistant_app", None)

    lines = [
        "# Codex user configuration",
        "# Managed Home Assistant defaults are merged into this file by the Codex App.",
        "# Project-specific overrides belong in /homeassistant/.codex/config.toml for trusted projects.",
        "",
    ]
    emit_table(lines, "", config)
    rendered = "\n".join(line for line in lines if line is not None).rstrip() + "\n"
    fd, tmp_name = tempfile.mkstemp(
        dir=config_path.parent,
        prefix=f".{config_path.name}.",
        suffix=".tmp",
        text=True,
    )
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(rendered)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp_path, config_path)
    finally:
        if tmp_path.exists():
            tmp_path.unlink()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
