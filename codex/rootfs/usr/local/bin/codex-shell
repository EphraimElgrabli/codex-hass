#!/usr/bin/env bash
set -u

source /etc/codex.bashrc

work_dir="${CODEX_WORK_DIR:-/homeassistant}"
if [[ ! -d "$work_dir" ]]; then
  work_dir="/homeassistant"
fi
cd "$work_dir" 2>/dev/null || cd /homeassistant

if command -v codex >/dev/null 2>&1; then
  while true; do
    codex
    codex_status=$?
    if [[ "$codex_status" -eq 0 ]]; then
      break
    fi

    echo
    echo "[WARN] Codex exited with status ${codex_status} before completing."
    read -r -p "Press Enter to retry Codex, or type 'shell' for a diagnostic shell: " next_action
    if [[ "$next_action" == "shell" ]]; then
      break
    fi
  done

  echo
  echo "[INFO] Codex closed. Starting a shell; run 'codex' to reopen Codex."
else
  echo "[ERROR] Codex CLI is not installed or is not on PATH."
fi

exec bash --rcfile /etc/codex.bashrc -i
