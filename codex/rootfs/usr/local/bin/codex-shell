#!/usr/bin/env bash
set -u

source /etc/codex.bashrc

work_dir="${CODEX_WORK_DIR:-/homeassistant}"
if [[ ! -d "$work_dir" ]]; then
  work_dir="/homeassistant"
fi
cd "$work_dir" 2>/dev/null || cd /homeassistant

repair_codex_config() {
  local codex_home="${CODEX_HOME:-${HOME}/.codex}"
  local config_path="${codex_home}/config.toml"

  if [[ -x /usr/local/bin/codex-merge-config ]]; then
    /usr/local/bin/codex-merge-config \
      "$config_path" \
      "${CODEX_DEFAULT_MODEL:-}" \
      "${CODEX_ENABLE_MCP:-true}" \
      "${CODEX_PERMISSIONS:-workspace}" \
      "${CODEX_APPROVAL_POLICY:-on-request}" || {
        echo "[WARN] Unable to repair Codex config before launch." >&2
      }
  fi
}

codex_command="/usr/local/bin/codex-hass-launcher"
if [[ ! -x "$codex_command" ]]; then
  codex_command="$(command -v codex || true)"
fi

if [[ -n "$codex_command" ]]; then
  while true; do
    repair_codex_config
    "$codex_command"
    codex_status=$?
    if [[ "$codex_status" -eq 0 ]]; then
      break
    fi

    echo
    echo "[WARN] Codex exited with status ${codex_status} before completing."
    read -r -p "Press Enter to retry Codex, or type 'shell' for a diagnostic shell: " next_action
    if [[ "$next_action" == "shell" ]]; then
      break
    fi
  done

  echo
  echo "[INFO] Codex closed. Starting a shell; run 'codex' to reopen Codex."
else
  echo "[ERROR] Codex CLI is not installed or is not on PATH."
fi

exec bash --rcfile /etc/codex.bashrc -i
